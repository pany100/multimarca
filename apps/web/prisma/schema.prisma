  ventaId           Int?
  presupuestoId     Int?
  ordenReparacion   OrdenReparacion? @relation("OrdenReparacionAjustesPrecio", fields: [ordenReparacionId], references: [id], onDelete: Cascade)
  venta             Venta?           @relation("VentaAjustesPrecio", fields: [ventaId], references: [id], onDelete: Cascade)
  presupuesto       Presupuesto?     @relation("PresupuestoAjustesPrecio", fields: [presupuestoId], references: [id], onDelete: Cascade)

  @@index([ordenReparacionId])
  @@index([ventaId])
  @@index([presupuestoId])
}

model DocumentoGeneral {
  id        Int         @id @default(autoincrement())
  titulo    String      @db.VarChar(255)
  archivo   CustomFile? @relation("DocumentoGeneralArchivo")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}
