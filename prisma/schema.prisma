generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                           Int                     @id @default(autoincrement())
  fullName                     String                  @db.VarChar(150)
  username                     String                  @db.VarChar(150)
  email                        String                  @unique @db.VarChar(150)
  password                     String                  @db.VarChar(300)
  reset_password_token         String?                 @db.VarChar(255)
  reset_password_token_expired DateTime?
  rolId                        Int
  activo                       Boolean                 @default(true)
  extracciones                 Extraccion[]
  ingresosManuales             IngresoManualDeDinero[]
  rol                          Rol                     @relation(fields: [rolId], references: [id])
  ordenesReparacion            OrdenReparacion[]     @relation("OrdenReparacionRevisadaPor")
  notificacionesInternas       NotificacionInterna[]
  presupuestos                 Presupuesto[]         @relation("PresupuestoAdministrativo")
  presupuestosCreados          Presupuesto[]         @relation("PresupuestoCreador")
  recordatoriosAgenda          RecordatorioAgenda[]
  tareasAdministrativas        TareaAdministrativa[] @relation("UsuarioTareas")
  tareasDiarias                TareaDiaria[]
  @@index([fullName])
  @@index([username])
  @@index([rolId], map: "Usuario_rolId_fkey")
}

model Permiso {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(100)
  roles Rol[]  @relation("PermisoToRol")
}

model Rol {
  id              Int              @id @default(autoincrement())
  name            String           @unique @db.VarChar(150)
  usuarios        Usuario[]
  categoriasGasto CategoriaGasto[] @relation("CategoriaGastoToRol")
  permisos        Permiso[]        @relation("PermisoToRol")

  @@index([name])
}

model Cliente {
  id                        Int                    @id @default(autoincrement())
  phone                     String?                @db.VarChar(20)
  fullName                  String                 @db.VarChar(150)
  email                     String?                @db.VarChar(150)
  birthday                  DateTime?
  address                   String?                @db.VarChar(200)
  city                      String?                @db.VarChar(100)
  state                     String?                @db.VarChar(100)
  postal_code               String?                @db.VarChar(10)
  tax_status                String?                @db.VarChar(50)
  dni                       String?                @unique @db.VarChar(20)
  can_receive_notifications Boolean                @default(true)
  cars                      Auto[]
  conversacionesWhatsApp    ConversacionWhatsApp[]
  pagosDeReparaciones       IngresoPorReparacion[]
  pagosDeVentas             IngresoPorVenta[]
  ventas                    Venta[]

  @@index([fullName])
  @@index([email])
  @@index([dni])
}

model Auto {
  id                Int               @id @default(autoincrement())
  patent            String            @unique @db.VarChar(150)
  model             String?           @db.VarChar(150)
  brand             String?           @db.VarChar(150)
  color             String?           @db.VarChar(50)
  year              Int?
  kms               Int?
  valves            String?           @db.VarChar(255)
  ownerId           Int
  chassis_number    String?           @db.VarChar(150)
  engine_number     String?           @db.VarChar(150)
  observations      String?           @db.VarChar(255)
  transmission_type String?           @db.VarChar(20)
  cedulaVerdePath   String?           @db.VarChar(1000)
  owner             Cliente           @relation(fields: [ownerId], references: [id])
  ordenesReparacion OrdenReparacion[] @relation("AutoOrdenReparacion")
  presupuestos      Presupuesto[]     @relation("AutoPresupuesto")
  turnos            Turno[]

  @@index([patent])
  @@index([ownerId])
}

model ControlMecanico {
  id                    Int                   @id @default(autoincrement())
  name                  String                @unique @db.VarChar(150)
  type                  String                @db.VarChar(10)
  ordenEnPdf            Int?
  pdfName               String?
  parentId              Int?                  
  parent                ControlMecanico?      @relation("Subcontroles", fields: [parentId], references: [id])
  subcontroles          ControlMecanico[]     @relation("Subcontroles")
  controlesEnReparacion ControlEnReparacion[]

  @@index([name])
  @@index([parentId])
}

model ManoDeObra {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(250)
  sellPrice Decimal? @db.Decimal(10, 2)

  @@index([name])
}

model Proveedor {
  id                    Int                   @id @default(autoincrement())
  name                  String                @unique @db.VarChar(150)
  address               String?               @db.VarChar(150)
  email                 String?               @db.VarChar(150)
  phone                 String?               @db.VarChar(150)
  mobile                String?               @db.VarChar(150)
  iva                   String?               @db.VarChar(150)
  cuit                  String?               @db.VarChar(150)
  numeroProveedor       Int
  gastos                Gasto[]
  ordenesDeCompra       OrdenDeCompra[]
  reparacionesDeTercero ReparacionDeTercero[]
  stocks                Stock[]

  @@index([name])
  @@index([cuit])
}

model Empleado {
  id                Int                       @id @default(autoincrement())
  name              String                    @unique @db.VarChar(150)
  start_date        DateTime?
  dni               String?
  address           String?                   @db.VarChar(150)
  city              String?                   @db.VarChar(150)
  state             String?                   @db.VarChar(150)
  postal_code       String?                   @db.VarChar(10)
  email             String?                   @db.VarChar(150)
  phone             String?                   @db.VarChar(150)
  birthday          DateTime?
  tipo              TipoEmpleado              @default(Mecanico)
  dniImagePath      String?                   @db.VarChar(1000)
  gastosRealizados  Gasto[]
  ordenesReparacion OrdenReparacionMecanico[]

  @@index([name])
  @@index([dni])
  @@index([dni], map: "Mecanico_dni_idx")
  @@index([name], map: "Mecanico_name_idx")
}

model OrdenReparacionMecanico {
  ordenReparacionId Int
  mecanicoId        Int
  mecanico          Empleado        @relation(fields: [mecanicoId], references: [id], onDelete: Cascade)
  ordenReparacion   OrdenReparacion @relation(fields: [ordenReparacionId], references: [id], onDelete: Cascade)
  detalle           String?         @db.Text

  @@id([ordenReparacionId, mecanicoId])
  @@index([mecanicoId], map: "OrdenReparacionMecanico_mecanicoId_fkey")
}

model Stock {
  id                     Int                   @id @default(autoincrement())
  name                   String                @db.VarChar(250)
  brand                  String                @db.VarChar(250)
  buyPrice               Decimal               @db.Decimal(10, 2)
  units                  Int?
  restockValue           Int?
  markup                 Float?
  proveedorId            Int
  label                  String?               @db.VarChar(250)
  notificacionesInternas NotificacionInterna[]
  ordenDeCompraItems     OrdenDeCompraItem[]
  repuestosUsados        RepuestoUsado[]
  proveedor              Proveedor             @relation(fields: [proveedorId], references: [id])

  @@index([name])
  @@index([brand])
  @@index([proveedorId])
}

model OrdenDeCompra {
  id          Int                 @id @default(autoincrement())
  fecha       DateTime            @default(now())
  precioTotal Decimal             @db.Decimal(10, 2)
  proveedorId Int
  proveedor   Proveedor           @relation(fields: [proveedorId], references: [id])
  items       OrdenDeCompraItem[]

  @@index([proveedorId])
  @@index([fecha])
}

model OrdenDeCompraItem {
  id              Int           @id @default(autoincrement())
  cantidad        Int
  stockId         Int
  ordenDeCompraId Int
  ordenDeCompra   OrdenDeCompra @relation(fields: [ordenDeCompraId], references: [id], onDelete: Cascade)
  stock           Stock         @relation(fields: [stockId], references: [id])

  @@index([stockId])
  @@index([ordenDeCompraId])
}

model Extraccion {
  id             Int            @id @default(autoincrement())
  monto          Decimal        @db.Decimal(10, 2)
  fecha          DateTime       @default(now())
  usuarioId      Int
  motivo         String         @db.VarChar(150)
  tipoOperacionId Int?
  tipoOperacion   TipoDeOperacion? @relation(fields: [tipoOperacionId], references: [id])
  moneda         Moneda         @default(Peso)
  dolarId        Int?
  dolar          Dolar?         @relation(fields: [dolarId], references: [id])
  usuario        Usuario        @relation(fields: [usuarioId], references: [id])
  chequeId  Int?
  cheque    Cheque?    @relation(fields: [chequeId], references: [id])

  @@index([usuarioId])
  @@index([fecha])
  @@index([dolarId], map: "Extraccion_dolarId_fkey")
}

model Gasto {
  id          Int            @id @default(autoincrement())
  nombre      String         @db.VarChar(150)
  precio      Decimal        @db.Decimal(10, 2)
  fecha       DateTime
  categoriaId Int
  mecanicoId  Int?
  detalle     String?        @db.Text
  proveedorId Int?
  moneda      Moneda         @default(Peso)
  dolarId     Int?
  tipoOperacionId Int?
  tipoOperacion   TipoDeOperacion? @relation(fields: [tipoOperacionId], references: [id])
  categoria   CategoriaGasto @relation(fields: [categoriaId], references: [id])
  dolar       Dolar?         @relation(fields: [dolarId], references: [id])
  mecanico    Empleado?      @relation(fields: [mecanicoId], references: [id])
  proveedor   Proveedor?     @relation(fields: [proveedorId], references: [id])
  chequeId  Int?
  cheque    Cheque?    @relation(fields: [chequeId], references: [id])

  @@index([categoriaId])
  @@index([mecanicoId])
  @@index([proveedorId])
  @@index([fecha])
  @@index([dolarId], map: "Gasto_dolarId_fkey")
}

model CategoriaGasto {
  id     Int     @id @default(autoincrement())
  nombre String  @unique @db.VarChar(150)
  gastos Gasto[]
  roles  Rol[]   @relation("CategoriaGastoToRol")

  @@index([nombre])
}

model Venta {
  id        Int         @id @default(autoincrement())
  fecha     DateTime    @default(now())
  clienteId Int?
  informacionCliente     String? @db.Text
  dolarId   Int?
  cliente   Cliente?    @relation(fields: [clienteId], references: [id])
  dolar     Dolar?      @relation(fields: [dolarId], references: [id])
  descuento              Decimal                   @default(0.00) @db.Decimal(10, 2)
  descripcionDescuento   String?                   @db.VarChar(255)
  incremento             Decimal                   @default(0.00) @db.Decimal(10, 2)
  descripcionIncremento  String?                   @db.VarChar(255)
  reparacionesDeTercero  ReparacionDeTercero[]     @relation("VentaReparacionTercero")
  repuestosUsados        RepuestoUsado[]           @relation("VentaRepuestos")
  trabajosRealizados     TrabajoRealizado[]        @relation("VentaTrabajosRealizados")
  ingresos               IngresoPorVenta[]         @relation("VentaIngresos")

  estado                 EstadoVenta               @default(Presupuestado)

  @@index([clienteId])
  @@index([fecha])
  @@index([dolarId], map: "Venta_dolarId_fkey")
}

model NotificacionWhatsapp {
  id          Int      @id @default(autoincrement())
  description String   @db.VarChar(250)
  date        DateTime
  whatsappKey String   @db.VarChar(250)
  processed   Boolean  @default(false)
  informacion String?  @db.Text

  @@index([date])
  @@index([processed])
}

model OrdenReparacion {
  id                     Int                       @id @default(autoincrement())
  autoId                 Int
  fechaCreacion          DateTime                  @default(now())
  fechaEntradaReparacion DateTime?
  fechaSalidaReparacion  DateTime?
  kilometros             Int?
  observacionesCliente   String                    @db.Text
  observacionesEntrada   String                    @db.Text
  observacionesSalida    String                    @db.Text
  observacionesOcultas   String?                   @db.Text
  detallesDeTrabajo      String?                   @db.Text
  estado                 EstadoOrdenReparacion     @default(Presupuestado)
  pdfPath                String?                   @db.VarChar(255)
  recibos                Json?
  descuento              Decimal                   @default(0.00) @db.Decimal(10, 2)
  dolarId                Int?
  detalleControles       String?                   @db.Text
  descripcionDescuento   String?                   @db.VarChar(255)
  incrementoInterno      Decimal                   @default(0.00) @db.Decimal(10, 2)
  incremento             Decimal                   @default(0.00) @db.Decimal(10, 2)
  descripcionIncremento  String?                   @db.VarChar(255)
  revisadoPorId          Int?
  revisadoPor            Usuario?                  @relation("OrdenReparacionRevisadaPor", fields: [revisadoPorId], references: [id])
  controlesEnReparacion  ControlEnReparacion[]     @relation("OrdenReparacionControlesEnReparacion")
  ingresos               IngresoPorReparacion[]    @relation("OrdenReparacionIngresos")
  notificacionesInternas NotificacionInterna[]     @relation("OrdenReparacionNotificacionesInternas")
  auto                   Auto                      @relation("AutoOrdenReparacion", fields: [autoId], references: [id])
  dolar                  Dolar?                    @relation(fields: [dolarId], references: [id])
  mecanicos              OrdenReparacionMecanico[]
  pagos                  PagoAMecanico[]           @relation("OrdenReparacionPagos")
  reparacionesDeTercero  ReparacionDeTercero[]     @relation("OrdenReparacionReparacionTercero")
  repuestosUsados        RepuestoUsado[]           @relation("OrdenReparacionRepuestos")
  trabajosRealizados     TrabajoRealizado[]        @relation("OrdenReparacionTrabajosRealizados")
  
  @@index([autoId])
  @@index([fechaCreacion])
  @@index([estado])
  @@index([dolarId], map: "OrdenReparacion_dolarId_fkey")
}

model Presupuesto {
  id                     Int                       @id @default(autoincrement())
  autoId                 Int?
  auto                   Auto?                     @relation("AutoPresupuesto", fields: [autoId], references: [id])
  informacionAuto        String?                   @db.Text
  informacionCliente     String?                   @db.Text
  administrativoId       Int?
  administrativo         Usuario?                  @relation("PresupuestoAdministrativo", fields: [administrativoId], references: [id])
  creadorId              Int?
  creador                Usuario?                 @relation("PresupuestoCreador", fields: [creadorId], references: [id])
  fecha                  DateTime                  @default(now())
  fechaEnvio             DateTime?
  fechaRespuesta         DateTime?
  observacionesCliente   String                    @db.Text
  detallesDeTrabajo      String?                   @db.Text
  descuento              Decimal                   @default(0.00) @db.Decimal(10, 2)
  descripcionDescuento   String?                   @db.VarChar(255)
  dolarId                Int?
  dolar                  Dolar?                    @relation(fields: [dolarId], references: [id])
  incrementoInterno      Decimal                   @default(0.00) @db.Decimal(10, 2)
  incremento             Decimal                   @default(0.00) @db.Decimal(10, 2)
  descripcionIncremento  String?                   @db.VarChar(255)
  reparacionesDeTercero  ReparacionDeTercero[]     @relation("PresupuestoReparacionTercero")
  repuestosUsados        RepuestoUsado[]           @relation("PresupuestoRepuestos")
  trabajosRealizados     TrabajoRealizado[]        @relation("PresupuestoTrabajosRealizados")
  estado                 EstadoPresupuesto         @default(EnPreparacion)
  tareasAdministrativas  TareaAdministrativa[]     @relation("PresupuestoTareas")
  
  @@index([autoId])
  @@index([fecha])
  @@index([estado])
  @@index([dolarId], map: "Presupuesto_dolarId_fkey")
}

model RepuestoUsado {
  id                     Int                   @id @default(autoincrement())
  ordenReparacionId      Int?
  ventaId                Int?
  presupuestoId          Int?
  stockId                Int
  precioCompra           Decimal               @db.Decimal(10, 2)
  precioVenta            Decimal               @db.Decimal(10, 2)
  unidadesConsumidas     Int
  plantillaPresupuestoId Int?
  ordenReparacion        OrdenReparacion?      @relation("OrdenReparacionRepuestos", fields: [ordenReparacionId], references: [id], onDelete: Cascade)
  plantillaPresupuesto   PlantillaPresupuesto? @relation("PlantillaPresupuestoRepuestos", fields: [plantillaPresupuestoId], references: [id], onDelete: Cascade)
  stock                  Stock                 @relation(fields: [stockId], references: [id])
  venta                  Venta?                @relation("VentaRepuestos", fields: [ventaId], references: [id], onDelete: Cascade)
  presupuesto            Presupuesto?          @relation("PresupuestoRepuestos", fields: [presupuestoId], references: [id], onDelete: Cascade)

  @@index([ordenReparacionId])
  @@index([ventaId], map: "RepuestoUsado_ventaId_fkey")
  @@index([stockId])
  @@index([plantillaPresupuestoId], map: "RepuestoUsado_plantillaPresupuestoId_fkey")
}

model ReparacionDeTercero {
  id                     Int                   @id @default(autoincrement())
  nombre                 String                @db.VarChar(250)
  precioCompra           Decimal               @db.Decimal(10, 2)
  precioVenta            Decimal               @db.Decimal(10, 2)
  proveedorId            Int
  ordenReparacionId      Int?
  ventaId                Int?
  presupuestoId          Int?
  plantillaPresupuestoId Int?
  recibo                 String?               @db.VarChar(255)
  ordenReparacion        OrdenReparacion?      @relation("OrdenReparacionReparacionTercero", fields: [ordenReparacionId], references: [id], onDelete: Cascade)
  venta                  Venta?                @relation("VentaReparacionTercero", fields: [ventaId], references: [id], onDelete: Cascade)
  plantillaPresupuesto   PlantillaPresupuesto? @relation("PlantillaPresupuestoReparacionTercero", fields: [plantillaPresupuestoId], references: [id], onDelete: Cascade)
  proveedor              Proveedor             @relation(fields: [proveedorId], references: [id])
  presupuesto            Presupuesto?          @relation("PresupuestoReparacionTercero", fields: [presupuestoId], references: [id], onDelete: Cascade)

  @@index([nombre])
  @@index([proveedorId])
  @@index([ordenReparacionId], map: "ReparacionDeTercero_ordenReparacionId_fkey")
  @@index([ventaId], map: "ReparacionDeTercero_ventaId_fkey")
  @@index([plantillaPresupuestoId], map: "ReparacionDeTercero_plantillaPresupuestoId_fkey")
  
}

model TrabajoRealizado {
  id                     Int                   @id @default(autoincrement())
  ordenReparacionId      Int?
  ventaId                Int?
  presupuestoId          Int?
  precioUnitario         Decimal               @db.Decimal(10, 2)
  descripcion            String                @db.Text
  diasParaRecordatorio   Int?
  plantillaPresupuestoId Int?
  ordenReparacion        OrdenReparacion?      @relation("OrdenReparacionTrabajosRealizados", fields: [ordenReparacionId], references: [id], onDelete: Cascade)
  plantillaPresupuesto   PlantillaPresupuesto? @relation("PlantillaPresupuestoTrabajosRealizados", fields: [plantillaPresupuestoId], references: [id], onDelete: Cascade)
  venta                  Venta?                @relation("VentaTrabajosRealizados", fields: [ventaId], references: [id], onDelete: Cascade)
  presupuesto            Presupuesto?          @relation("PresupuestoTrabajosRealizados", fields: [presupuestoId], references: [id], onDelete: Cascade)

  @@index([ordenReparacionId])
  @@index([ventaId], map: "TrabajoRealizado_ventaId_fkey")
  @@index([plantillaPresupuestoId], map: "TrabajoRealizado_plantillaPresupuestoId_fkey")
  @@index([presupuestoId], map: "TrabajoRealizado_presupuestoId_fkey")
}

model PlantillaPresupuesto {
  id                    Int                   @id @default(autoincrement())
  nombre                String                @db.VarChar(255)
  reparacionesDeTercero ReparacionDeTercero[] @relation("PlantillaPresupuestoReparacionTercero")
  repuestosUsados       RepuestoUsado[]       @relation("PlantillaPresupuestoRepuestos")
  trabajosRealizados    TrabajoRealizado[]    @relation("PlantillaPresupuestoTrabajosRealizados")
}

model ControlEnReparacion {
  id                Int             @id @default(autoincrement())
  ordenReparacionId Int
  controlMecanicoId Int
  valor             String          @db.VarChar(255)
  controlMecanico   ControlMecanico @relation(fields: [controlMecanicoId], references: [id], onDelete: Cascade)
  ordenReparacion   OrdenReparacion @relation("OrdenReparacionControlesEnReparacion", fields: [ordenReparacionId], references: [id], onDelete: Cascade)

  @@index([ordenReparacionId])
  @@index([controlMecanicoId])
}

model PagoAMecanico {
  id                Int             @id @default(autoincrement())
  ordenReparacionId Int
  monto             Decimal?        @db.Decimal(10, 2)
  fechaPago         DateTime?
  ordenReparacion   OrdenReparacion @relation("OrdenReparacionPagos", fields: [ordenReparacionId], references: [id], onDelete: Cascade)

  @@index([ordenReparacionId])
  @@index([fechaPago])
}

model IngresoPorReparacion {
  id                Int             @id @default(autoincrement())
  fecha             DateTime        @default(now())
  clienteId         Int
  monto             Decimal         @db.Decimal(10, 2)
  descripcion       String          @db.Text
  ordenReparacionId Int
  reciboEnviado     Boolean         @default(false)
  moneda            Moneda          @default(Peso)
  dolarId           Int?
  cliente           Cliente         @relation(fields: [clienteId], references: [id])
  dolar             Dolar?          @relation(fields: [dolarId], references: [id])
  ordenReparacion   OrdenReparacion @relation("OrdenReparacionIngresos", fields: [ordenReparacionId], references: [id], onDelete: Cascade)
  tipoOperacionId Int?
  tipoOperacion   TipoDeOperacion? @relation(fields: [tipoOperacionId], references: [id])
  chequeId  Int?
  cheque    Cheque?    @relation(fields: [chequeId], references: [id])

  @@index([fecha])
  @@index([clienteId])
  @@index([ordenReparacionId])
  @@index([dolarId], map: "IngresoPorReparacion_dolarId_fkey")
}


model IngresoPorVenta {
  id                Int             @id @default(autoincrement())
  fecha             DateTime        @default(now())
  clienteId         Int?
  informacionCliente String? @db.Text
  monto             Decimal         @db.Decimal(10, 2)
  descripcion       String          @db.Text
  ventaId           Int
  reciboEnviado     Boolean         @default(false)
  moneda            Moneda          @default(Peso)
  dolarId           Int?
  cliente           Cliente?         @relation(fields: [clienteId], references: [id])
  dolar             Dolar?          @relation(fields: [dolarId], references: [id])
  venta             Venta @relation("VentaIngresos", fields: [ventaId], references: [id], onDelete: Cascade)
  tipoOperacionId Int?
  tipoOperacion   TipoDeOperacion? @relation(fields: [tipoOperacionId], references: [id])
  chequeId  Int?
  cheque    Cheque?    @relation(fields: [chequeId], references: [id])

  @@index([fecha])
  @@index([clienteId])
  @@index([ventaId])
  @@index([dolarId], map: "IngresoPorVenta_dolarId_fkey")
}

model Dolar {
  id                    Int                     @id @default(autoincrement())
  fecha                 DateTime                @unique @default(now())
  oficial               Decimal                 @db.Decimal(10, 2)
  blue                  Decimal                 @db.Decimal(10, 2)
  extraccion            Extraccion[]
  gasto                 Gasto[]
  ingresoManualDeDinero IngresoManualDeDinero[]
  ingresosPorReparacion IngresoPorReparacion[]
  ingresosPorVenta      IngresoPorVenta[]
  ordenReparacion       OrdenReparacion[]
  venta                 Venta[]
  presupuesto           Presupuesto[]
  perdidas              Perdidas[]

  @@index([fecha])
}

model NotificacionInterna {
  id                Int                     @id @default(autoincrement())
  fecha             DateTime                @default(now())
  titulo            String                  @db.VarChar(255)
  texto             String                  @db.Text
  leida             Boolean                 @default(false)
  tipo              TipoNotificacionInterna
  stockId           Int?
  ordenReparacionId Int?
  ordenReparacion   OrdenReparacion?        @relation("OrdenReparacionNotificacionesInternas", fields: [ordenReparacionId], references: [id], onDelete: Cascade)
  stock             Stock?                  @relation(fields: [stockId], references: [id])
  userId            Int?
  user              Usuario?                @relation(fields: [userId], references: [id])
  @@index([fecha])
  @@index([leida])
  @@index([tipo])
  @@index([stockId])
  @@index([ordenReparacionId])
  @@index([userId])
}

model ConversacionWhatsApp {
  id            Int                @id @default(autoincrement())
  clienteId     Int
  iniciada      DateTime           @default(now())
  ultimoMensaje DateTime           @default(now())
  estado        EstadoConversacion @default(Activa)
  cliente       Cliente            @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  mensajes      MensajeWhatsApp[]

  @@index([clienteId])
  @@index([iniciada])
  @@index([ultimoMensaje])
}

model MensajeWhatsApp {
  id             Int                  @id @default(autoincrement())
  from           String               @db.VarChar(50)
  body           String               @db.Text
  tipo           String               @db.VarChar(20)
  timestamp      DateTime             @default(now())
  conversacionId Int
  read           Boolean              @default(false)
  to             String               @db.VarChar(50)
  conversacion   ConversacionWhatsApp @relation(fields: [conversacionId], references: [id], onDelete: Cascade)

  @@index([from])
  @@index([timestamp])
  @@index([conversacionId])
}

model IngresoManualDeDinero {
  id             Int            @id @default(autoincrement())
  monto          Decimal        @db.Decimal(10, 2)
  fecha          DateTime
  descripcion    String?        @db.Text
  moneda         Moneda         @default(Peso)
  dolarId        Int?
  tipoOperacionId Int?
  tipoOperacion   TipoDeOperacion? @relation(fields: [tipoOperacionId], references: [id])
  usuarioId      Int
  dolar          Dolar?         @relation(fields: [dolarId], references: [id])
  usuario        Usuario        @relation(fields: [usuarioId], references: [id])
  chequeId  Int?
  cheque    Cheque?    @relation(fields: [chequeId], references: [id])

  @@index([usuarioId])
  @@index([dolarId], map: "IngresoManualDeDinero_dolarId_fkey")
}

model Cheque {
  id Int @id @default(autoincrement())
  numero String @unique @db.VarChar(255)
  fechaEmision DateTime @default(now())
  fechaCobro  DateTime
  banco String @db.VarChar(255)
  importe Decimal @db.Decimal(10, 2)
  owner String @db.VarChar(255)
  picturePath String @db.VarChar(255)

  rechazado           Boolean     @default(false)
  fechaRechazo        DateTime?  
  gastosAdministrativos Decimal? @db.Decimal(10, 2)
  observaciones        String?     @db.Text

  extraccion Extraccion[]
  gasto Gasto[]
  ingresoPorReparacion IngresoPorReparacion[]
  ingresoManualDeDinero IngresoManualDeDinero[]
  ingresoPorVenta IngresoPorVenta[]
}

model TipoDeOperacion {
  id                    Int                     @id @default(autoincrement())
  label                 String                  @unique @db.VarChar(100)
  extracciones          Extraccion[]
  gastos                Gasto[]
  esIngreso             Boolean @default(true)
  esGasto               Boolean @default(true)
  ingresosPorReparacion IngresoPorReparacion[]
  ingresosManualDeDinero IngresoManualDeDinero[]
  ingresosPorVenta IngresoPorVenta[]

  @@index([label])
}

model Feriado {
  id          Int      @id @default(autoincrement())
  fecha       DateTime
  descripcion String   @db.VarChar(255)

  @@index([fecha])
}

model Turno {
  id        Int      @id @default(autoincrement())
  hora      String
  fecha     DateTime
  problema  String   @db.Text
  autoId    Int
  auto      Auto     @relation(fields: [autoId], references: [id])

  @@index([fecha])
  @@index([autoId])
}

model RecordatorioAgenda {
  id          Int       @id @default(autoincrement())
  userId      Int?
  user        Usuario?  @relation(fields: [userId], references: [id])
  titulo      String    @db.VarChar(255)
  descripcion String?   @db.Text
  fecha       DateTime
  hecho       Boolean   @default(false)  
  @@index([fecha])
}

model TareaAdministrativa {
  id            Int         @id @default(autoincrement())
  descripcion   String      @db.Text
  presupuestoId Int
  usuarioId     Int
  presupuesto   Presupuesto @relation("PresupuestoTareas", fields: [presupuestoId], references: [id], onDelete: Cascade)
  usuario       Usuario     @relation("UsuarioTareas", fields: [usuarioId], references: [id])

  @@index([presupuestoId])
  @@index([usuarioId])
}

model TareaDiaria {
  id          Int       @id @default(autoincrement())
  descripcion String    @db.Text
  realizado   Boolean   @default(false)
  fecha       DateTime  @default(now())
  usuarioId   Int?
  usuario     Usuario?  @relation(fields: [usuarioId], references: [id])

  @@index([fecha])
  @@index([usuarioId])
}

model Perdidas { 
  id          Int       @id @default(autoincrement())
  fecha       DateTime  @default(now())
  monto       Decimal   @db.Decimal(10, 2)
  descripcion String    @db.VarChar(255)
  moneda      Moneda    @default(Peso)
  dolar       Dolar?    @relation(fields: [dolarId], references: [id])
  dolarId     Int?
  recuperaciones Recuperacion[]
}

model Recuperacion {
  id          Int       @id @default(autoincrement())
  fecha       DateTime  @default(now())
  monto       Decimal   @db.Decimal(10, 2)
  perdida     Perdidas  @relation(fields: [perdidaId], references: [id], onDelete: Cascade)
  perdidaId   Int
  detalle     String?   @db.VarChar(255)
}

enum TipoEmpleado {
  Mecanico
  Administrativo
}

enum TipoOperacion {
  EFECTIVO
  TRANSFERENCIA
  CHEQUE
  DEBITO_AUTOMATICO_TARJETA_CREDITO
}

enum EstadoOrdenReparacion {
  Presupuestado
  EnProgreso
  Aceptado
  Terminado
  SeRetira
}

enum EstadoPresupuesto {
  EnPreparacion
  Terminado
  Enviado
  ADefinir
  Aceptado
  Rechazado
  Descartado
}

enum TipoNotificacionInterna {
  REPOSICION_STOCK
  REPARACION_TERMINADA
  CHEQUE_POR_VENCER
  TURNOS_DEL_DIA
  RECORDATORIOS_MANO_DE_OBRA
  CHEQUE_RECHAZADO
  EVENTO_AGENDA
}

enum EstadoConversacion {
  Activa
  Cerrada
}

enum Moneda {
  Dolar
  Peso
}

enum EstadoVenta {
  Presupuestado
  Preparado
  Entregado
  Cerrado
}
