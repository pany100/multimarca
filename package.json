{
  "name": "multimarca",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "ts-node --esm --project tsconfig.server.json server.ts",
    "prebuild": "rm -rf .next",
    "build": "node --max-old-space-size=4096 node_modules/.bin/next build && tsc --project tsconfig.server.json",
    "start": "NODE_ENV=production node dist/server.js",
    "build-and-start": "npm run build && npm start",
    "lint": "next lint",
    "setup-test-db": "NODE_ENV=test node --experimental-specifier-resolution=node --loader ts-node/esm tests/setupTestDb.ts",
    "test": "yarn setup-test-db && jest --runInBand",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.616.0",
    "@aws-sdk/s3-request-presigner": "^3.616.0",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@faker-js/faker": "^8.4.1",
    "@hookform/resolvers": "^3.9.0",
    "@mui/icons-material": "^5.16.4",
    "@mui/material": "^5.16.4",
    "@mui/x-data-grid": "^7.11.0",
    "@mui/x-date-pickers": "^8.1.0",
    "@prisma/client": "^5.17.0",
    "@types/lodash": "^4.17.7",
    "@types/uuid": "^10.0.0",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.4.3",
    "cookies-next": "^4.2.1",
    "csv-parse": "^5.5.6",
    "date-fns": "^3.6.0",
    "dayjs": "^1.11.13",
    "formik": "^2.4.6",
    "jose": "^5.6.3",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "next": "14.2.5",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.14",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^22.14.0",
    "react": "^18",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18",
    "react-dropzone": "^14.2.3",
    "react-hook-form": "^7.52.1",
    "react-to-print": "^2.15.1",
    "recharts": "^2.12.7",
    "sharp": "^0.33.4",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "uuid": "^10.0.0",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.15",
    "@types/puppeteer": "^7.0.4",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/yup": "^0.32.0",
    "dotenv": "^16.4.5",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.9",
    "prisma": "^5.17.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "ts-node --esm prisma/seed.ts"
  }
}
