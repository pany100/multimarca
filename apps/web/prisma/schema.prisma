generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                           Int                     @id @default(autoincrement())
  fullName                     String                  @db.VarChar(150)
  username                     String                  @db.VarChar(150)
  email                        String                  @unique @db.VarChar(150)
  password                     String                  @db.VarChar(300)
  reset_password_token         String?                 @db.VarChar(255)
  reset_password_token_expired DateTime?
  rolId                        Int
  activo                       Boolean                 @default(true)
  extracciones                 Extraccion[]
  ingresosManuales             IngresoManualDeDinero[]
  notificacionesInternas       NotificacionInterna[]
  ordenesReparacion            OrdenReparacion[]       @relation("OrdenReparacionRevisadaPor")
  presupuestos                 Presupuesto[]           @relation("PresupuestoAdministrativo")
  presupuestosCreados          Presupuesto[]           @relation("PresupuestoCreador")
  recordatoriosAgenda          RecordatorioAgenda[]
  tareasAdministrativas        TareaAdministrativa[]   @relation("UsuarioTareas")
  tareasDiarias                TareaDiaria[]
  rol                          Rol                     @relation(fields: [rolId], references: [id])

  @@index([fullName])
  @@index([username])
  @@index([rolId], map: "Usuario_rolId_fkey")
}

model Permiso {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(100)
  roles Rol[]  @relation("PermisoToRol")
}

model Rol {
  id              Int              @id @default(autoincrement())
  name            String           @unique @db.VarChar(150)
  usuarios        Usuario[]
  categoriasGasto CategoriaGasto[] @relation("CategoriaGastoToRol")
  permisos        Permiso[]        @relation("PermisoToRol")

  @@index([name])
}

model Cliente {
  id                        Int                    @id @default(autoincrement())
  phone                     String?                @db.VarChar(20)
  fullName                  String                 @db.VarChar(150)
  email                     String?                @db.VarChar(150)
  birthday                  DateTime?
  address                   String?                @db.VarChar(200)
  city                      String?                @db.VarChar(100)
  state                     String?                @db.VarChar(100)
  postal_code               String?                @db.VarChar(10)
  tax_status                String?                @db.VarChar(50)
  dni                       String?                @unique @db.VarChar(20)
  can_receive_notifications Boolean                @default(true)
  cars                      Auto[]
  conversacionesWhatsApp    ConversacionWhatsApp[]
  pagosDeReparaciones       IngresoPorReparacion[]
  pagosDeVentas             IngresoPorVenta[]
  ventas                    Venta[]

  @@index([fullName])
  @@index([email])
  @@index([dni])
}

model Auto {
  id                Int               @id @default(autoincrement())
  patent            String            @unique @db.VarChar(150)
  model             String?           @db.VarChar(150)
  brand             String?           @db.VarChar(150)
  color             String?           @db.VarChar(50)
  year              Int?
  kms               Int?
  valves            String?           @db.VarChar(255)
  ownerId           Int
  chassis_number    String?           @db.VarChar(150)
  engine_number     String?           @db.VarChar(150)
  observations      String?           @db.VarChar(255)
  transmission_type String?           @db.VarChar(20)
  tipoCombustible   TipoCombustible?
  cedulaVerdePath   String?           @db.VarChar(1000)
  owner             Cliente           @relation(fields: [ownerId], references: [id])
  ordenesReparacion OrdenReparacion[] @relation("AutoOrdenReparacion")
  presupuestos      Presupuesto[]     @relation("AutoPresupuesto")
  turnos            Turno[]

  @@index([patent])
  @@index([ownerId])
}

enum TipoCombustible {
  Nafta
  Diesel
  Electrico
  Hibrido
}

model ControlMecanico {
  id                    Int                   @id @default(autoincrement())
  name                  String                @unique @db.VarChar(150)
  type                  String                @db.VarChar(10)
  ordenEnPdf            Int?
  pdfName               String?
  parentId              Int?
  controlesEnReparacion ControlEnReparacion[]
  parent                ControlMecanico?      @relation("Subcontroles", fields: [parentId], references: [id])
  subcontroles          ControlMecanico[]     @relation("Subcontroles")

  @@index([name])
  @@index([parentId])
}

model ManoDeObra {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(250)
  pdfName   String?
  sellPrice Decimal? @db.Decimal(10, 2)

  @@index([name])
}

model Proveedor {
  id                    Int                   @id @default(autoincrement())
  name                  String                @unique @db.VarChar(150)
  address               String?               @db.VarChar(150)
  email                 String?               @db.VarChar(150)
  phone                 String?               @db.VarChar(150)
  mobile                String?               @db.VarChar(150)
  iva                   String?               @db.VarChar(150)
  cuit                  String?               @db.VarChar(150)
  alias                 String?               @db.VarChar(150)
  numeroProveedor       Int
  gastos                Gasto[]
  ordenesDeCompra       OrdenDeCompra[]
  reparacionesDeTercero ReparacionDeTercero[]
  stocks                Stock[]
  revisado        Boolean          @default(false)

  @@index([name])
  @@index([cuit])
}

model PrestamoHerramientas {
  id          Int      @id @default(autoincrement())
  nombre      String   @db.VarChar(150)
  fecha       DateTime
  herramienta String  @db.Text
  devuelto    Boolean  @default(false)
}

model InformacionSensible {
  id          Int      @id @default(autoincrement())
  titulo      String  @db.VarChar(200)
  texto       String  @db.Text
}

model InformacionGeneral {
  id          Int      @id @default(autoincrement())
  titulo      String  @db.VarChar(200)
  texto       String  @db.Text
}


model DatosVarios {
  id          Int      @id @default(autoincrement())
  titulo      String  @db.VarChar(200)
  texto       String  @db.Text
}

model Empleado {
  id                Int                       @id @default(autoincrement())
  name              String                    @unique @db.VarChar(150)
  start_date        DateTime?
  dni               String?
  claveFiscal       String?                   @db.VarChar(50)
  address           String?                   @db.VarChar(150)
  city              String?                   @db.VarChar(150)
  state             String?                   @db.VarChar(150)
  postal_code       String?                   @db.VarChar(10)
  email             String?                   @db.VarChar(150)
  phone             String?                   @db.VarChar(150)
  birthday          DateTime?
  tipo              TipoEmpleado              @default(Mecanico)
  dniImagePath      String?                   @db.VarChar(1000)
  contactoEmergencia String?                   @db.VarChar(150)
  licenciaConducirPath           CustomFile?   @relation("EmpleadoLicenciaConducir")
  inscripcionMonotributoPath     CustomFile?   @relation("EmpleadoInscripcionMonotributo")
  recategorizacionMonotributoPath CustomFile?   @relation("EmpleadoRecategorizacionMonotributo")
  curriculumPath                CustomFile?   @relation("EmpleadoCurriculum")
  credencialPagoPath            CustomFile?   @relation("EmpleadoCredencialPago")
  dniFrentePath                 CustomFile?   @relation("EmpleadoDniFrente")
  dniDorsoPath                  CustomFile?   @relation("EmpleadoDniDorso")
  fechaBaja                   DateTime?
  ausenciasProgramadas        AusenciaProgramada[]
  certificadosEstudio         CertificadoEstudio[]
  sueldos                     Sueldo[]
  notasAdministrativas        NotaAdministrativa[]

  gastosRealizados  Gasto[]
  ordenesReparacion OrdenReparacionMecanico[]
  inasistencias     Inasistencia[]
  llegadasTarde     LlegadaTarde[]
  horasExtra        HoraExtra[]
  apercibimientos   Apercibimiento[]
  premios           Premio[]

  @@index([name])
  @@index([dni])
  @@index([dni], map: "Mecanico_dni_idx")
  @@index([name], map: "Mecanico_name_idx")
}

model CertificadoEstudio {
  id         Int      @id @default(autoincrement())
  empleadoId Int
  nombre     String?  @db.VarChar(255)
  ruta       CustomFile? @relation("CertificadoEstudioRuta")
  fecha            DateTime    @default(now())
  descripcion      String?      @db.Text
  empleado   Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)

  @@index([empleadoId])
}

model Sueldo {
  id         Int      @id @default(autoincrement())
  empleadoId Int
  fecha      DateTime @default(now())
  monto      Decimal  @db.Decimal(10, 2)
  descripcion String? @db.Text
  empleado   Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)

  @@index([empleadoId])
}

model NotaAdministrativa {
  id          Int      @id @default(autoincrement())
  empleadoId  Int
  fecha       DateTime @default(now())
  titulo      String   @db.VarChar(255)
  descripcion String?  @db.Text
  empleado    Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)

  @@index([empleadoId])
}

model Premio {
  id               Int         @id @default(autoincrement())
  empleadoId       Int
  empleado         Empleado    @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  fecha            DateTime    @default(now())
  tipo             TipoPremio  @default(Reconocimiento)
  descripcion      String?      @db.Text
  monto            Decimal?     @db.Decimal(10,2)
  fechaCreacion    DateTime     @default(now())

  @@index([empleadoId])
}

enum TipoPremio {
  Reconocimiento
  Economico
  Productividad
  Especial
}

model HoraExtra {
  id              Int         @id @default(autoincrement())
  empleadoId      Int
  empleado        Empleado    @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  fecha           DateTime
  horasTotales    Decimal      @db.Decimal(5,2)
  motivo          String?      @db.VarChar(255)
  fechaCreacion    DateTime      @default(now())
  @@index([empleadoId])
}

model Apercibimiento {
  id               Int          @id @default(autoincrement())
  empleadoId       Int
  empleado         Empleado     @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  fecha            DateTime     @default(now())
  tipo             TipoApercibimiento @default(Leve)
  motivo           String        @db.VarChar(255)
  fechaCreacion    DateTime      @default(now())

  @@index([empleadoId])
}

enum TipoApercibimiento {
  Verbal
  Leve
  Grave
  MuyGrave
}

model Inasistencia {
  id                   Int        @id @default(autoincrement())
  empleadoId           Int
  empleado             Empleado   @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  fecha                DateTime
  motivo               String?     @db.VarChar(255)
  tipo                 TipoInasistencia @default(Medica)
  certificadoMedicoPath CustomFile? @relation("InasistenciaCertificado")
  fechaCreacion        DateTime   @default(now())

  @@index([empleadoId])
}

enum TipoInasistencia {
  Medica
  Personal
  SinAviso
  Otro
}

model LlegadaTarde {
  id               Int        @id @default(autoincrement())
  empleadoId       Int
  empleado         Empleado   @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  fecha            DateTime
  minutosRetraso   Int
  motivo           String?      @db.VarChar(255)
  estado           EstadoLlegada @default(Justificada)
  certificadoPath  CustomFile?  @relation("LlegadaTardeCertificado")
  fechaCreacion    DateTime      @default(now())

  @@index([empleadoId])
}

enum EstadoLlegada {
  Justificada
  Injustificada
  Pendiente
}

model AusenciaProgramada {
  id               Int         @id @default(autoincrement())
  empleadoId       Int
  empleado         Empleado    @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  fechaDesde       DateTime
  fechaHasta       DateTime
  estado           EstadoAusencia @default(Pendiente)
  observaciones    String?       @db.Text
  esGoceSueldo     Boolean       @default(true)
  fechaCreacion    DateTime      @default(now())
  fechaAprobacion  DateTime?
  tipo             TipoAusencia @default(Vacaciones)

  @@index([empleadoId])
}

model OrdenReparacionMecanico {
  id                Int             @id @default(autoincrement())
  ordenReparacionId Int
  mecanicoId        Int
  detalle           String?         @db.Text
  mecanico          Empleado        @relation(fields: [mecanicoId], references: [id], onDelete: Restrict)
  ordenReparacion   OrdenReparacion @relation(fields: [ordenReparacionId], references: [id], onDelete: Cascade)

  @@unique([ordenReparacionId, mecanicoId])
  @@index([mecanicoId], map: "OrdenReparacionMecanico_mecanicoId_fkey")
}

model Stock {
  id                     Int                   @id @default(autoincrement())
  name                   String                @db.VarChar(250)
  brand                  String                @db.VarChar(250)
  buyPrice               Decimal               @db.Decimal(10, 2)
  /// Cantidad en stock; decimal para ítems fraccionables (ej. litros).
  units                  Decimal?              @db.Decimal(10, 3)
  restockValue           Int?
  markup                 Float?
  buyIva                 Float?
  sellIva                Float?
  proveedorId            Int
  label                  String                 @unique @db.VarChar(250)
  reportName             String?                @db.Text
  sector                 String?                @db.Text
  carBrand               String?                @db.Text
  /// Si true, el ítem se puede vender/consumir en cantidades decimales (ej. litros: 0.5, 1.25).
  fraccionable            Boolean               @default(false)
  notificacionesInternas NotificacionInterna[]
  ordenDeCompraItems     OrdenDeCompraItem[]
  repuestosUsados        RepuestoUsado[]
  proveedor              Proveedor             @relation(fields: [proveedorId], references: [id])

  @@index([name])
  @@index([brand])
  @@index([proveedorId])
}

model OrdenDeCompra {
  id          Int                 @id @default(autoincrement())
  fecha       DateTime            @default(now())
  precioTotal Decimal             @db.Decimal(10, 2)
  percepcion  Decimal             @default(0) @db.Decimal(10, 2)
  proveedorId Int
  proveedor   Proveedor           @relation(fields: [proveedorId], references: [id])
  items       OrdenDeCompraItem[]

  @@index([proveedorId])
  @@index([fecha])
}

model OrdenDeCompraItem {
  id              Int           @id @default(autoincrement())
  cantidad        Int
  precioUnitario  Decimal?      @db.Decimal(10, 2)
  iva             Float?
  stockId         Int
  ordenDeCompraId Int
  ordenDeCompra   OrdenDeCompra @relation(fields: [ordenDeCompraId], references: [id], onDelete: Cascade)
  stock           Stock         @relation(fields: [stockId], references: [id])

  @@index([stockId])
  @@index([ordenDeCompraId])
}

model Extraccion {
  id              Int              @id @default(autoincrement())
  monto           Decimal          @db.Decimal(10, 2)
  fecha           DateTime         @default(now())
  usuarioId       Int
  motivo          String           @db.VarChar(150)
  tipoOperacionId Int
  moneda          Moneda           @default(Peso)
  dolarId         Int?
  chequeId        Int?
  cheque          Cheque?          @relation(fields: [chequeId], references: [id])
  dolar           Dolar?           @relation(fields: [dolarId], references: [id])
  tipoOperacion   TipoDeOperacion  @relation(fields: [tipoOperacionId], references: [id])
  usuario         Usuario          @relation(fields: [usuarioId], references: [id])
  revisado        Boolean          @default(false)
  gastosBancarios Decimal          @default(0) @db.Decimal(10, 2)
  gastosArba      Decimal          @default(0) @db.Decimal(10, 2)
  cotizacionDolar Decimal?         @db.Decimal(10, 2)

  @@index([usuarioId])
  @@index([fecha])
  @@index([dolarId], map: "Extraccion_dolarId_fkey")
  @@index([chequeId], map: "Extraccion_chequeId_fkey")
  @@index([tipoOperacionId], map: "Extraccion_tipoOperacionId_fkey")
}

model Gasto {
  id              Int              @id @default(autoincrement())
  nombre          String           @db.VarChar(150)
  precio          Decimal          @db.Decimal(10, 2)
  fecha           DateTime
  categoriaId     Int
  mecanicoId      Int?
  detalle         String?          @db.Text
  proveedorId     Int?
  moneda          Moneda           @default(Peso)
  dolarId         Int?
  tipoOperacionId Int
  chequeId        Int?
  categoria       CategoriaGasto   @relation(fields: [categoriaId], references: [id])
  cheque          Cheque?          @relation(fields: [chequeId], references: [id])
  dolar           Dolar?           @relation(fields: [dolarId], references: [id])
  mecanico        Empleado?        @relation(fields: [mecanicoId], references: [id])
  proveedor       Proveedor?       @relation(fields: [proveedorId], references: [id])
  tipoOperacion   TipoDeOperacion  @relation(fields: [tipoOperacionId], references: [id])
  revisado        Boolean          @default(false)
  gastosBancarios Decimal          @default(0) @db.Decimal(10, 2)
  gastosArba      Decimal          @default(0) @db.Decimal(10, 2)
  cotizacionDolar Decimal?         @db.Decimal(10, 2)

  @@index([categoriaId])
  @@index([mecanicoId])
  @@index([proveedorId])
  @@index([fecha])
  @@index([dolarId], map: "Gasto_dolarId_fkey")
  @@index([chequeId], map: "Gasto_chequeId_fkey")
  @@index([tipoOperacionId], map: "Gasto_tipoOperacionId_fkey")
}

model CategoriaGasto {
  id     Int     @id @default(autoincrement())
  nombre String  @unique @db.VarChar(150)
  gastos Gasto[]
  roles  Rol[]   @relation("CategoriaGastoToRol")

  @@index([nombre])
}

model Venta {
  id                    Int                   @id @default(autoincrement())
  fecha                 DateTime              @default(now())
  clienteId             Int?
  informacionCliente    String?               @db.Text
  dolarId               Int?
  descuento             Decimal               @default(0.00) @db.Decimal(10, 2)
  descripcionDescuento  String?               @db.VarChar(255)
  incremento            Decimal               @default(0.00) @db.Decimal(10, 2)
  descripcionIncremento String?               @db.VarChar(255)
  porcentajeRecargo           Decimal               @default(0.00) @db.Decimal(10, 2)
  descuentoParaManoDeObra     Decimal               @default(0.00) @db.Decimal(10, 2)
  estado                      EstadoVenta           @default(Borrador)
  cedulaFile                  CustomFile?           @relation("VentaCedula")
  ingresos              IngresoPorVenta[]     @relation("VentaIngresos")
  reparacionesDeTercero ReparacionDeTercero[] @relation("VentaReparacionTercero")
  repuestosUsados       RepuestoUsado[]       @relation("VentaRepuestos")
  trabajosRealizados    TrabajoRealizado[]    @relation("VentaTrabajosRealizados")
  cliente               Cliente?              @relation(fields: [clienteId], references: [id])
  dolar                 Dolar?                @relation(fields: [dolarId], references: [id])
  ajustesPrecio         AjustePrecio[]        @relation("VentaAjustesPrecio")
  modoAjustes           ModoAjustes           @default(sobreTotalBase)

  @@index([clienteId])
  @@index([fecha])
  @@index([dolarId], map: "Venta_dolarId_fkey")
}

model NotificacionWhatsapp {
  id          Int      @id @default(autoincrement())
  description String   @db.VarChar(250)
  date        DateTime
  whatsappKey String   @db.VarChar(250)
  processed   Boolean  @default(false)
  informacion String?  @db.Text

  @@index([date])
  @@index([processed])
}

model OrdenReparacion {
  id                     Int                       @id @default(autoincrement())
  autoId                 Int
  fechaCreacion          DateTime                  @default(now())
  fechaEntradaReparacion DateTime?
  fechaSalidaReparacion  DateTime?
  kilometros             Int?
  observacionesCliente   String                    @db.Text
  observacionesEntrada   String                    @db.Text
  observacionesSalida    String                    @db.Text
  observacionesOcultas   String?                   @db.Text
  detallesDeTrabajo      String?                   @db.Text
  estado                 EstadoOrdenReparacion     @default(Presupuestado)
  pdfPath                String?                   @db.VarChar(255)
  recibos                String?                   @db.LongText
  descuento              Decimal                   @default(0.00) @db.Decimal(10, 2)
  dolarId                Int?
  detalleControles       String?                   @db.Text
  porcentajeRecargo      Decimal                   @default(0.00) @db.Decimal(10, 2)
  descripcionDescuento   String?                   @db.VarChar(255)
  incrementoInterno      Decimal                   @default(0.00) @db.Decimal(10, 2)
  incremento                Decimal                   @default(0.00) @db.Decimal(10, 2)
  descripcionIncremento     String?                   @db.VarChar(255)
  descuentoParaManoDeObra   Decimal                   @default(0.00) @db.Decimal(10, 2)
  revisadoPorId             Int?
  controlesEnReparacion     ControlEnReparacion[]     @relation("OrdenReparacionControlesEnReparacion")
  scannerFile            CustomFile?               @relation("ORepScanner")
  recibosFiles           CustomFile[]              @relation("ORepRecibos")
  ingresos               IngresoPorReparacion[]    @relation("OrdenReparacionIngresos")
  notificacionesInternas NotificacionInterna[]     @relation("OrdenReparacionNotificacionesInternas")
  auto                   Auto                      @relation("AutoOrdenReparacion", fields: [autoId], references: [id])
  dolar                  Dolar?                    @relation(fields: [dolarId], references: [id])
  revisadoPor            Usuario?                  @relation("OrdenReparacionRevisadaPor", fields: [revisadoPorId], references: [id])
  mecanicos              OrdenReparacionMecanico[]
  pagos                  PagoAMecanico[]           @relation("OrdenReparacionPagos")
  reparacionesDeTercero  ReparacionDeTercero[]     @relation("OrdenReparacionReparacionTercero")
  repuestosUsados        RepuestoUsado[]           @relation("OrdenReparacionRepuestos")
  trabajosRealizados     TrabajoRealizado[]        @relation("OrdenReparacionTrabajosRealizados")
  ajustesPrecio          AjustePrecio[]            @relation("OrdenReparacionAjustesPrecio")
  modoAjustes            ModoAjustes               @default(sobreTotalBase)

  @@index([autoId])
  @@index([fechaCreacion])
  @@index([estado])
  @@index([dolarId], map: "OrdenReparacion_dolarId_fkey")
  @@index([revisadoPorId], map: "OrdenReparacion_revisadoPorId_fkey")
}

model CustomFile {
  id                    Int                  @id @default(autoincrement())
  tempPath              String               @db.VarChar(255)
  finalPath             String?              @db.VarChar(255)
  status                EstadoArchivo        @default(Pendiente)
  promotedAt            DateTime?
  ordenReparacionId     Int?                 @unique
  reciboORepId          Int?
  reparacionDeTerceroId Int?                 @unique
  presupuestoCedulaId   Int?                 @unique
  ventaCedulaId         Int?                 @unique
  empleadoLicenciaConducirId        Int?     @unique
  empleadoInscripcionMonotributoId  Int?     @unique
  empleadoRecategorizacionMonotributoId Int?  @unique
  empleadoCurriculumId  Int?                 @unique
  empleadoCredencialPagoId Int?              @unique
  empleadoDniFrenteId   Int?                 @unique
  empleadoDniDorsoId    Int?                 @unique
  llegadaTardeCertificadoId Int?             @unique
  inasistenciaCertificadoId Int?            @unique
  certificadoEstudioRutaId Int?              @unique
  ordenReparacion       OrdenReparacion?     @relation("ORepScanner", fields: [ordenReparacionId], references: [id])
  reciboDeORep          OrdenReparacion?     @relation("ORepRecibos", fields: [reciboORepId], references: [id])
  reparacionDeTercero   ReparacionDeTercero? @relation("ReparacionDeTerceroRecibos", fields: [reparacionDeTerceroId], references: [id])
  presupuestoCedula     Presupuesto?         @relation("PresupuestoCedula", fields: [presupuestoCedulaId], references: [id])
  ventaCedula           Venta?               @relation("VentaCedula", fields: [ventaCedulaId], references: [id])
  empleadoLicenciaConducir         Empleado? @relation("EmpleadoLicenciaConducir", fields: [empleadoLicenciaConducirId], references: [id])
